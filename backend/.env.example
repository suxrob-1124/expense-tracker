# Copy this file to .env and fill in real values before starting the app.
# Generate AES key:  openssl rand -base64 32
# Generate JWT secret: openssl rand -base64 64

# Required — app refuses to start without these
FIELD_ENCRYPTION_KEY=<base64-encoded-32-byte-aes-key>
JWT_SECRET=<base64-encoded-hs256-secret>

# Optional — defaults to "postgres" for local dev
# DB_USER=postgres
# DB_PASSWORD=postgres
