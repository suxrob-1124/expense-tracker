<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="20260513-008-add-column" author="system">
        <addColumn tableName="transactions">
            <column name="payment_method_id" type="UUID"/>
        </addColumn>

        <rollback>
            <dropColumn tableName="transactions" columnName="payment_method_id"/>
        </rollback>
    </changeSet>

    <changeSet id="20260513-008-add-fk" author="system">
        <addForeignKeyConstraint
                baseTableName="transactions"
                baseColumnNames="payment_method_id"
                constraintName="fk_transactions_payment_method_id"
                referencedTableName="payment_methods"
                referencedColumnNames="id"
                onDelete="SET NULL"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="transactions"
                                      constraintName="fk_transactions_payment_method_id"/>
        </rollback>
    </changeSet>

    <changeSet id="20260513-008-add-index" author="system">
        <createIndex indexName="idx_transactions_payment_method_id" tableName="transactions">
            <column name="payment_method_id"/>
        </createIndex>

        <rollback>
            <dropIndex indexName="idx_transactions_payment_method_id" tableName="transactions"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
